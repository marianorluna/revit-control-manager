<Window x:Class="ControlManager.UI.PrivacyPolicyWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Control Manager — Política de Privacidad"
        MinWidth="640"
        MinHeight="480"
        Width="720"
        Height="560"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip"
        Loaded="Window_Loaded">
    <DockPanel Margin="12">
        <StackPanel DockPanel.Dock="Bottom"
                    Margin="0,12,0,0"
                    HorizontalAlignment="Right"
                    Orientation="Horizontal">
            <Button MinWidth="160"
                    Margin="0,0,8,0"
                    Padding="12,6"
                    Content="Ver en navegador"
                    Click="OpenInBrowser_Click" />
            <Button MinWidth="100"
                    Padding="12,6"
                    Content="Cerrar"
                    IsCancel="True"
                    IsDefault="True"
                    Click="Close_Click" />
        </StackPanel>
        <WebBrowser x:Name="PolicyBrowser" />
    </DockPanel>
</Window>
