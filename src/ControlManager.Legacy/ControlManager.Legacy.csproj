  <!-- Copia ControlManager.dll y dependencias NuGet al mismo directorio que Revit carga (misma carpeta que el .addin). -->
  <Target Name="DeployAddinToRevitAddinsFolder" AfterTargets="Build" Condition="'$(RevitAddinsPath)' != '' AND '$(DeployRevitAddinToFolder)' != 'false'">
    <MakeDir Directories="$(RevitAddinsPath)" />
    <!-- IgnoreExitCode: Revit bloquea DLLs en uso; el build no debe fallar. Cierra Revit y recompila para actualizar Addins. -->
    <Exec Command="cmd /c copy /Y &quot;$(TargetDir)*.dll&quot; &quot;$(RevitAddinsPath)&quot;" IgnoreExitCode="true" />
    <Exec Command="cmd /c copy /Y &quot;$(MSBuildProjectDirectory)\ControlManager.addin&quot; &quot;$(RevitAddinsPath)ControlManager.addin&quot;" IgnoreExitCode="true" Condition="Exists('$(MSBuildProjectDirectory)\ControlManager.addin')" />
    <Message Importance="high" Text="Control Manager: copia a $(RevitAddinsPath) intentada ($(Configuration)). Si Revit estaba abierto, ciérralo y vuelve a compilar." />
  </Target>

